# ------------------------------------------------------------------
# QSL Maintenance Management System — environment configuration
# Copy this file to ".env" and fill in real values before deploying.
# ------------------------------------------------------------------

# PostgreSQL connection string.
# When running with docker-compose, the host is the service name "db".
DATABASE_URL="postgresql://qsl:qsl_password@db:5432/qsl?schema=public"

# Secret used to sign login session tokens (JWT).
# Generate a strong one:  openssl rand -base64 48
AUTH_SECRET="change-me-to-a-long-random-string"

# How long a login session stays valid.
SESSION_TTL_HOURS="12"

# Public base URL of the app (used in notification emails).
APP_URL="http://localhost:3000"

# Domain for the production Caddy HTTPS proxy (docker-compose.prod.yml).
# Point this domain's DNS A record at the server, then Caddy auto-issues TLS.
# Leave blank for local/dev. When set, also set APP_URL to https://your.domain
DOMAIN=""

# Session cookie security. Leave unset for the safe default (Secure ON in
# production — required over HTTPS / the public internet). Set to "false" ONLY
# for a trusted local network where the app is reached over plain HTTP by LAN
# IP (otherwise phones/laptops can't log in). Never "false" on a public host.
# COOKIE_SECURE="false"

# Access codes for the two oversight roles (Project / Technical Manager).
# These are set on the seeded oversight accounts; change after first login.
PROJECT_MANAGER_CODE="MAGADI2026"
TECHNICAL_MANAGER_CODE="TECH2026"

# ---- Email notifications (optional but recommended) --------------
# Leave EMAIL_ENABLED=false to run without sending mail (events are still
# logged to the audit trail). Set true and fill SMTP details to enable.
EMAIL_ENABLED="false"
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="notifications@yourdomain.com"
SMTP_PASS="your-smtp-app-password"
EMAIL_FROM="QSL Reports <notifications@yourdomain.com>"

# ---- Maintenance schedule reminders ------------------------------
# Secret that authorises the cron endpoint /api/schedule/reminders.
# Generate one:  openssl rand -hex 24
CRON_SECRET="change-me-cron-secret"
# Comma-separated recipients of the due/overdue digest (optional).
SCHEDULE_ALERT_EMAILS=""

# ---- First admin account created by the seed script --------------
SEED_ADMIN_EMAIL="admin@qalibrated.co.ke"
SEED_ADMIN_PASSWORD="ChangeMe!2026"
SEED_ADMIN_NAME="QSL Administrator"
# Set "false" once real staff are onboarded to stop seeding demo accounts.
SEED_DEMO_ACCOUNTS="true"
