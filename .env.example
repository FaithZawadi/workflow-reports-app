# ------------------------------------------------------------------
# QSL Maintenance Management System — environment configuration
# Copy this file to ".env" and fill in real values before deploying.
# ------------------------------------------------------------------

# PostgreSQL connection string.
# When running with docker-compose, the host is the service name "db".
DATABASE_URL="postgresql://qsl:qsl_password@db:5432/qsl?schema=public"

# Secret used to sign login session tokens (JWT).
# Generate a strong one:  openssl rand -base64 48
AUTH_SECRET="change-me-to-a-long-random-string"

# How long a login session stays valid.
SESSION_TTL_HOURS="12"

# Public base URL of the app — MUST match the domain users open in the browser,
# because it is written into every notification email link.
# e.g. production:  https://reports.qalibrated.com
APP_URL="http://localhost:3000"

# Domain for the production Caddy HTTPS proxy (docker-compose.prod.yml).
# Point this domain's DNS A record at the server, then Caddy auto-issues TLS.
# Leave blank for local/dev. When set, also set APP_URL to https://your.domain
DOMAIN=""

# Session cookie security. Leave unset for the safe default (Secure ON in
# production — required over HTTPS / the public internet). Set to "false" ONLY
# for a trusted local network where the app is reached over plain HTTP by LAN
# IP (otherwise phones/laptops can't log in). Never "false" on a public host.
# COOKIE_SECURE="false"

# ---- Email notifications (optional but recommended) --------------
# Leave EMAIL_ENABLED=false to run without sending mail (events are still shown
# in the in-app notification bell and logged to the audit trail). Set true and
# fill the SMTP details to also send email.
#
# The SMTP_USER must be a REAL mailbox with SMTP login (a Google Group / alias
# cannot authenticate). To send AS a branded no-reply address:
#   • Google Workspace: create noreply@<domain> as a user, turn on 2-Step
#     Verification, then generate an App Password (Mail) — that is SMTP_PASS.
#     (If App Passwords are blocked by admin policy, use smtp-relay.gmail.com.)
#   • Gmail: SMTP_PASS must be a 16-char App Password, NOT the account password.
# EMAIL_FROM should match SMTP_USER (or a verified "Send mail as" alias),
# otherwise the provider rewrites the From header.
#
# Add SPF (include:_spf.google.com) + DKIM for the sending domain so mail isn't
# marked as spam.
EMAIL_ENABLED="false"
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="faith.zawadi@qalibrated.com"
SMTP_PASS="B1rdi@2026"
EMAIL_FROM="QSL Reports <faith.zawadi@qalibrated.com>"

# ---- Maintenance reminders, contracts & escalation ---------------
# Secret that authorises the cron endpoint /api/schedule/reminders. The bundled
# "reminders" container calls it daily; escalation & contract reminders won't
# fire unless this is set. Generate one:  openssl rand -hex 24
CRON_SECRET="change-me-cron-secret"
# Comma-separated recipients of the due/overdue digest + escalation notices.
SCHEDULE_ALERT_EMAILS=""
# Days-before-due at which each contract service reminder is emailed to the
# client contact and the QSL Technical Manager (at least three). Default 30,14,7,1.
CONTRACT_REMINDER_DAYS="30,14,7,1"
# Escalate a report still awaiting review/approval after this many days. Default 3.
ESCALATE_AFTER_DAYS="3"

# ---- First admin account created by the seed script --------------
SEED_ADMIN_EMAIL="admin@qalibrated.co.ke"
SEED_ADMIN_PASSWORD="ChangeMe!2026"
SEED_ADMIN_NAME="QSL Administrator"
# Set "false" once real staff are onboarded to stop seeding demo accounts.
SEED_DEMO_ACCOUNTS="true"
