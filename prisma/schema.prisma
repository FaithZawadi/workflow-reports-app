// QSL Maintenance Management System — database schema
// PostgreSQL via Prisma.

generator client {
  provider      = "prisma-client-js"
  // "native" covers local dev; the musl target covers the Alpine Docker image.
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  TECHNICIAN
  ENGINEER
  SUPERVISOR
  MANAGER
  PROJECT_MANAGER
  TECHNICAL_MANAGER
  ADMIN
}

enum ReportStatus {
  PENDING_SUPERVISOR
  PENDING_MANAGER
  APPROVED
  REJECTED
}

enum MaintenanceFrequency {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  SEMIANNUAL
  ANNUAL
  CUSTOM
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         Role
  phone        String?
  site         String? // for technicians: their site within the plant
  active       Boolean  @default(true)

  clientId String?
  client   Client? @relation(fields: [clientId], references: [id])

  reports     Report[]      @relation("AuthoredReports")
  trailEvents TrailEvent[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([role])
  @@index([clientId])
}

model Client {
  id        String     @id @default(cuid())
  name      String     @unique
  active    Boolean    @default(true)
  users     User[]
  reports   Report[]
  schedules Schedule[]
  createdAt DateTime   @default(now())
}

// A recurring maintenance obligation for one weighbridge (e.g. WB01 daily on
// TATA Magadi's dispatch-gate weighbridge). Filing the matching report advances it.
model Schedule {
  id           String               @id @default(cuid())
  clientId     String?
  client       Client?              @relation(fields: [clientId], references: [id])
  clientName   String // snapshot
  site         String?
  weighbridgeId String?

  template     String // WB01..WB06
  templateName String
  frequency    MaintenanceFrequency
  intervalDays Int? // used when frequency = CUSTOM

  assignedName  String?
  assignedEmail String?

  lastDoneAt       DateTime?
  nextDueAt        DateTime
  lastReportSerial String?

  active      Boolean  @default(true)
  notes       String?
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([nextDueAt])
  @@index([clientId])
  @@index([template])
  @@index([active])
}

model Report {
  id           String       @id @default(cuid())
  serial       String       @unique
  template     String // WB01..WB06
  templateName String
  status       ReportStatus @default(PENDING_SUPERVISOR)

  clientId   String?
  client     Client? @relation(fields: [clientId], references: [id])
  clientName String // snapshot at time of submission
  site       String?

  weighbridgeId String?

  authorId   String?
  author     User?   @relation("AuthoredReports", fields: [authorId], references: [id])
  authorName String // snapshot

  supervisorEmail String
  managerEmail    String

  // Structured form payload: { values, checks, grids, runs, weekly }
  data Json

  photos      Photo[]
  trailEvents TrailEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([template])
  @@index([clientId])
  @@index([authorId])
  @@index([createdAt])
}

model Photo {
  id       String   @id @default(cuid())
  reportId String
  report   Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)
  // Base64 data URL (JPEG). For very large deployments swap to object storage.
  dataUrl  String   @db.Text
  caption  String?
  takenAt  DateTime?
  gpsLat   Float?
  gpsLng   Float?
  gpsAcc   Int?
  order    Int      @default(0)

  @@index([reportId])
}

model TrailEvent {
  id       String   @id @default(cuid())
  reportId String
  report   Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)
  action   String
  byName   String
  byUserId String?
  byUser   User?    @relation(fields: [byUserId], references: [id])
  comment  String?
  at       DateTime @default(now())

  @@index([reportId])
}

// Atomic per-year-per-template serial counter.
model Counter {
  scope String @id // e.g. "WB01-2026"
  value Int    @default(0)
}

// System-wide audit trail of create/update/delete actions across users,
// reports and schedules — visible to administrators.
model AuditLog {
  id        String   @id @default(cuid())
  at        DateTime @default(now())
  actorId   String?
  actorName String
  actorRole String?
  action    String // CREATE | UPDATE | DELETE | APPROVE | REJECT
  entity    String // USER | REPORT | SCHEDULE
  entityId  String?
  summary   String

  @@index([at])
  @@index([entity])
  @@index([actorId])
}
