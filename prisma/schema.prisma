// QSL Maintenance Management System — database schema
// PostgreSQL via Prisma.

generator client {
  provider      = "prisma-client-js"
  // "native" covers local dev; the musl target covers the Alpine Docker image.
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  TECHNICIAN
  ENGINEER
  SUPERVISOR
  MANAGER
  PROJECT_MANAGER
  TECHNICAL_MANAGER
  ADMIN
}

enum ReportStatus {
  PENDING_SUPERVISOR
  PENDING_MANAGER
  APPROVED
  REJECTED
}

enum TaskStatus {
  OPEN
  IN_PROGRESS
  BLOCKED
  DONE
}

enum ServiceType {
  MONTHLY_SERVICE
  QUARTERLY_SERVICE
  ANNUAL_CALIBRATION
  BREAKDOWN_SERVICE
}

enum MaintenanceFrequency {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  SEMIANNUAL
  ANNUAL
  CUSTOM
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  // Primary role — kept for display, reviewer routing and backward compatibility.
  role         Role
  // Every role this user holds. A user may hold more than one (e.g. technician
  // AND engineer); their access is the union across all of them. Always includes
  // `role`.
  roles        Role[]   @default([])
  phone        String?
  site         String? // for technicians: their site within the plant
  active       Boolean  @default(true)

  clientId String?
  client   Client? @relation(fields: [clientId], references: [id])

  reports     Report[]      @relation("AuthoredReports")
  trailEvents TrailEvent[]
  feedback    Feedback[]
  assignedTasks Task[]      @relation("AssignedTasks")
  // Weighbridges this user is responsible for (supervisors/managers may have many).
  weighbridges Weighbridge[] @relation("UserWeighbridges")
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([role])
  @@index([clientId])
}

model Client {
  id           String        @id @default(cuid())
  name         String        @unique
  active       Boolean       @default(true)
  users        User[]
  reports      Report[]
  schedules    Schedule[]
  weighbridges Weighbridge[]
  sites        Site[]
  projects     Project[]
  tasks        Task[]
  contracts    Contract[]
  createdAt    DateTime      @default(now())
}

// A site / location registered by an administrator. Reports pick one from a
// dropdown when filing. Optionally tied to a client (plant); a site with no
// client is available to everyone.
model Site {
  id        String   @id @default(cuid())
  name      String
  clientId  String?
  client    Client?  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@index([active])
}

// A star rating + optional comment left by a user from the periodic in-app
// "How's the app working?" prompt. Administrators read these under /feedback.
model Feedback {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  userName  String
  userEmail String
  rating    Int // 1..5
  comment   String?
  createdAt DateTime @default(now())

  @@index([createdAt])
}

// Customer feedback / enquiry collected AFTER a service (monthly, quarterly,
// annual calibration or breakdown). Submitted by the client — usually via a
// shared link — so no app account is required. Read by managers/admin.
model ServiceFeedback {
  id           String      @id @default(cuid())
  serviceType  ServiceType
  clientName   String
  contactName  String?
  contactEmail String?
  contactPhone String?
  weighbridge  String?
  serviceDate  DateTime?
  rating       Int? // 1..5, optional
  comments     String? // feedback / enquiry text
  createdAt    DateTime    @default(now())

  @@index([serviceType])
  @@index([createdAt])
}

// A project groups work (tasks, and by extension the reports for its site) so it
// can be classified by project and by company (client). Administrators and
// managers register projects.
model Project {
  id          String   @id @default(cuid())
  name        String
  clientId    String?
  client      Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  description String?
  active      Boolean  @default(true)
  tasks       Task[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([clientId])
  @@index([active])
}

// A task assigned to a member of staff and tracked to completion. Tasks are
// classified under a project and/or a client (company) and can reference a
// weighbridge.
model Task {
  id            String     @id @default(cuid())
  title         String
  description   String?
  status        TaskStatus @default(OPEN)
  priority      String? // LOW | MEDIUM | HIGH
  projectId     String?
  project       Project?   @relation(fields: [projectId], references: [id], onDelete: SetNull)
  clientId      String?
  client        Client?    @relation(fields: [clientId], references: [id], onDelete: SetNull)
  clientName    String?
  weighbridgeId String?
  assignedToId  String?
  assignedTo    User?      @relation("AssignedTasks", fields: [assignedToId], references: [id], onDelete: SetNull)
  assignedName  String?
  assignedEmail String?
  createdById   String?
  createdName   String?
  dueAt         DateTime?
  doneAt        DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([status])
  @@index([projectId])
  @@index([clientId])
  @@index([assignedToId])
  @@index([dueAt])
}

// A running maintenance/service contract for a client. The system emails a
// service reminder to the client contact and the QSL Technical Manager several
// times (see CONTRACT_REMINDER_DAYS) before each service falls due.
model Contract {
  id                    String               @id @default(cuid())
  name                  String
  clientId              String?
  client                Client?              @relation(fields: [clientId], references: [id], onDelete: SetNull)
  clientName            String
  clientEmail           String? // client contact who receives reminders
  technicalManagerEmail String? // QSL technical manager who receives reminders
  frequency             MaintenanceFrequency @default(QUARTERLY)
  intervalDays          Int? // for CUSTOM frequency
  startDate             DateTime?
  endDate               DateTime?
  nextServiceAt         DateTime
  lastServiceAt         DateTime?
  // Lead-times (in days before due) already emailed for the current cycle, so a
  // daily job doesn't send the same reminder twice.
  remindersSent         Int[]                @default([])
  active                Boolean              @default(true)
  notes                 String?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  @@index([clientId])
  @@index([active])
  @@index([nextServiceAt])
}

// A weighbridge registered by an administrator. Reports and schedules pick one
// from a dropdown; the make/model/serial/capacity auto-fill the service forms.
model Weighbridge {
  id         String  @id @default(cuid())
  clientId   String
  client     Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  site       String?
  label      String // e.g. "WB-1 Dispatch Gate"
  makeModel  String?
  serialNo   String?
  capacity   String? // capacity / division
  deckLength String?
  active     Boolean @default(true)

  users User[] @relation("UserWeighbridges")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@index([active])
}

// A recurring maintenance obligation for one weighbridge (e.g. WB01 daily on
// TATA Magadi's dispatch-gate weighbridge). Filing the matching report advances it.
model Schedule {
  id           String               @id @default(cuid())
  clientId     String?
  client       Client?              @relation(fields: [clientId], references: [id])
  clientName   String // snapshot
  site         String?
  weighbridgeId String?

  template     String // WB01..WB06
  templateName String
  frequency    MaintenanceFrequency
  intervalDays Int? // used when frequency = CUSTOM

  assignedName  String?
  assignedEmail String?

  lastDoneAt       DateTime?
  nextDueAt        DateTime
  lastReportSerial String?

  active      Boolean  @default(true)
  notes       String?
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([nextDueAt])
  @@index([clientId])
  @@index([template])
  @@index([active])
}

model Report {
  id           String       @id @default(cuid())
  serial       String       @unique
  template     String // WB01..WB06
  templateName String
  status       ReportStatus @default(PENDING_SUPERVISOR)

  clientId   String?
  client     Client? @relation(fields: [clientId], references: [id])
  clientName String // snapshot at time of submission
  site       String?

  weighbridgeId String?

  authorId   String?
  author     User?   @relation("AuthoredReports", fields: [authorId], references: [id])
  authorName String // snapshot

  supervisorEmail String
  managerEmail    String

  // Structured form payload: { values, checks, grids, runs, weekly }
  data Json

  photos      Photo[]
  trailEvents TrailEvent[]

  // Set when an overdue pending approval was auto-escalated, so we don't re-nag.
  escalatedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([template])
  @@index([clientId])
  @@index([authorId])
  @@index([createdAt])
}

model Photo {
  id       String   @id @default(cuid())
  reportId String
  report   Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)
  // Base64 data URL (JPEG). For very large deployments swap to object storage.
  dataUrl  String   @db.Text
  caption  String?
  takenAt  DateTime?
  gpsLat   Float?
  gpsLng   Float?
  gpsAcc   Int?
  order    Int      @default(0)

  @@index([reportId])
}

model TrailEvent {
  id       String   @id @default(cuid())
  reportId String
  report   Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)
  action   String
  byName   String
  byUserId String?
  byUser   User?    @relation(fields: [byUserId], references: [id])
  comment  String?
  at       DateTime @default(now())

  @@index([reportId])
}

// Atomic per-year-per-template serial counter.
model Counter {
  scope String @id // e.g. "WB01-2026"
  value Int    @default(0)
}

// System-wide audit trail of create/update/delete actions across users,
// reports and schedules — visible to administrators.
model AuditLog {
  id        String   @id @default(cuid())
  at        DateTime @default(now())
  actorId   String?
  actorName String
  actorRole String?
  action    String // CREATE | UPDATE | DELETE | APPROVE | REJECT
  entity    String // USER | REPORT | SCHEDULE
  entityId  String?
  summary   String

  @@index([at])
  @@index([entity])
  @@index([actorId])
}
