// QSL Maintenance Management System — database schema
// PostgreSQL via Prisma.

generator client {
  provider      = "prisma-client-js"
  // "native" covers local dev; the musl target covers the Alpine Docker image.
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  TECHNICIAN
  ENGINEER
  SUPERVISOR
  MANAGER
  PROJECT_MANAGER
  TECHNICAL_MANAGER
  ADMIN
  // A client contact. Restricted login: files calibration requests and requests
  // quotations, and sees only their own — nothing else in the system.
  CLIENT
  // Human Resources. Records and reviews training feedback and downloads the
  // feedback sheets as PDF.
  HR
}

enum CalibrationType {
  IN_SITU
  LAB
}

enum CalibrationRequestStatus {
  SUBMITTED
  ACCEPTED
  REJECTED
}

enum QuotationStatus {
  REQUESTED // client asked for a quote
  QUOTED // PM/TM issued the quote
  ACCEPTED // client accepted the quote
  DECLINED // client declined the quote
}

enum ReportStatus {
  PENDING_SUPERVISOR
  PENDING_MANAGER
  APPROVED
  REJECTED
}

enum TaskStatus {
  OPEN
  IN_PROGRESS
  BLOCKED
  DONE
}

enum ServiceType {
  MONTHLY_SERVICE
  QUARTERLY_SERVICE
  ANNUAL_CALIBRATION
  BREAKDOWN_SERVICE
}

// An in-app notification shown in the header bell. Created alongside the email
// notifications for the same events (new report, review/approval, decision,
// task assignment, failure alerts, escalations).
model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String // REVIEW | APPROVAL | DECISION | TASK | FAILURE | SCHEDULE | SYSTEM
  title     String
  body      String?
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, read])
  @@index([createdAt])
}

enum MaintenanceFrequency {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  SEMIANNUAL
  ANNUAL
  CUSTOM
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  // When the password was last set. Users are prompted to change it every 60
  // days (see src/lib/passwordPolicy.js). Backfilled to the rollout date so the
  // clock starts "today" for everyone.
  passwordChangedAt DateTime?
  name         String
  // Primary role — kept for display, reviewer routing and backward compatibility.
  role         Role
  // Every role this user holds. A user may hold more than one (e.g. technician
  // AND engineer); their access is the union across all of them. Always includes
  // `role`.
  roles        Role[]   @default([])
  phone        String?
  site         String? // for technicians: their site within the plant
  active       Boolean  @default(true)

  clientId String?
  client   Client? @relation(fields: [clientId], references: [id])

  reports     Report[]      @relation("AuthoredReports")
  trailEvents TrailEvent[]
  feedback    Feedback[]
  assignedTasks Task[]      @relation("AssignedTasks")
  notifications Notification[]
  // Weighbridges this user is responsible for (supervisors/managers may have many).
  weighbridges Weighbridge[] @relation("UserWeighbridges")
  // Weighbridges for which this user is the Client/Manager (approval routing).
  managedWeighbridges Weighbridge[] @relation("WeighbridgeManager")
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([role])
  @@index([clientId])
}

model Client {
  id           String        @id @default(cuid())
  name         String        @unique
  active       Boolean       @default(true)
  users        User[]
  reports      Report[]
  schedules    Schedule[]
  weighbridges Weighbridge[]
  sites        Site[]
  projects     Project[]
  tasks        Task[]
  contracts    Contract[]
  calibrationRequests CalibrationRequest[]
  quotations   Quotation[]
  createdAt    DateTime      @default(now())
}

// A site / location registered by an administrator. Reports pick one from a
// dropdown when filing. Optionally tied to a client (plant); a site with no
// client is available to everyone.
model Site {
  id        String   @id @default(cuid())
  name      String
  clientId  String?
  client    Client?  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@index([active])
}

// A star rating + optional comment left by a user from the periodic in-app
// "How's the app working?" prompt. Administrators read these under /feedback.
model Feedback {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  userName  String
  userEmail String
  rating    Int // 1..5
  comment   String?
  createdAt DateTime @default(now())

  @@index([createdAt])
}

// Customer feedback / enquiry collected AFTER a service (monthly, quarterly,
// annual calibration or breakdown). Submitted by the client — usually via a
// shared link — so no app account is required. Read by managers/admin.
// Customer Satisfaction Survey Form (QSL/QP/004/CSSF). Filled by customers on a
// PUBLIC page (no login); read by managers/admin under Customer feedback.
model ServiceFeedback {
  id           String       @id @default(cuid())
  serviceType  ServiceType? // legacy single type — optional now
  serviceTypes String[]     @default([]) // CSSF §1: WEIGHBRIDGE | BALANCE | MASS_STANDARDS
  clientName   String // Organization name
  contactName  String?
  contactEmail String?
  contactPhone String?
  weighbridge  String?
  serviceDate  DateTime?
  rating       Int? // mirrors `overall`, kept for the list average
  comments     String?

  // §2 evaluation criteria: { "2.1": 1..5, … "2.10": 1..5 }
  criteria           Json?
  // §4 complaints
  hadProblem         Boolean?
  problemDetail      String?
  complaintHandling  String? // NA | VERY_UNSATISFACTORY | … | VERY_SATISFACTORY
  // §5 improvement
  didWell            String?
  improve            String?
  additionalServices String?
  // §6 overall assessment
  overall   Int? // 1..5
  useAgain  String? // YES | NO | NOT_SURE
  recommend String? // YES | NO | NOT_SURE

  createdAt DateTime @default(now())

  @@index([serviceType])
  @@index([createdAt])
}

// Training feedback recorded by HR after a staff/client training session. HR
// records each attendee's evaluation, reviews them, and downloads the sheets as
// PDF. Criteria are rated 1..5 (see src/lib/training.js).
model TrainingFeedback {
  id            String    @id @default(cuid())
  trainingTitle String    @default("Qalibrated Systems MMS Training")
  trainingDate  DateTime?
  trainer       String? // facilitator
  organization  String? // organization / site
  mode          String? // IN_PERSON | VIRTUAL
  traineeName   String
  traineeRole   String? // role / designation
  department    String?

  // Section rated 1..5: { "t1": 1..5, … "t11": 1..5 }
  criteria Json?
  overall  Int? // 1..5

  didWell           String? // most useful part
  improve           String? // what could be improved
  additionalSupport String? // support / follow-up needed
  recommend         String? // YES | NO | MAYBE

  // Who recorded it (the HR user, if entered from the admin side; null for a
  // public submission).
  recordedById   String?
  recordedByName String?

  createdAt DateTime @default(now())

  @@index([createdAt])
}

// A project groups work (tasks, and by extension the reports for its site) so it
// can be classified by project and by company (client). Administrators and
// managers register projects.
model Project {
  id          String   @id @default(cuid())
  name        String
  clientId    String?
  client      Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  description String?
  active      Boolean  @default(true)
  tasks       Task[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([clientId])
  @@index([active])
}

// A task assigned to a member of staff and tracked to completion. Tasks are
// classified under a project and/or a client (company) and can reference a
// weighbridge.
model Task {
  id            String     @id @default(cuid())
  title         String
  description   String?
  status        TaskStatus @default(OPEN)
  priority      String? // LOW | MEDIUM | HIGH
  projectId     String?
  project       Project?   @relation(fields: [projectId], references: [id], onDelete: SetNull)
  clientId      String?
  client        Client?    @relation(fields: [clientId], references: [id], onDelete: SetNull)
  clientName    String?
  weighbridgeId String?
  assignedToId  String?
  assignedTo    User?      @relation("AssignedTasks", fields: [assignedToId], references: [id], onDelete: SetNull)
  assignedName  String?
  assignedEmail String?
  createdById   String?
  createdName   String?
  dueAt         DateTime?
  doneAt        DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([status])
  @@index([projectId])
  @@index([clientId])
  @@index([assignedToId])
  @@index([dueAt])
}

// A running maintenance/service contract for a client. The system emails a
// service reminder to the client contact and the QSL Technical Manager several
// times (see CONTRACT_REMINDER_DAYS) before each service falls due.
model Contract {
  id                    String               @id @default(cuid())
  name                  String
  clientId              String?
  client                Client?              @relation(fields: [clientId], references: [id], onDelete: SetNull)
  clientName            String
  clientEmail           String? // client contact who receives reminders
  technicalManagerEmail String? // QSL technical manager who receives reminders
  frequency             MaintenanceFrequency @default(QUARTERLY)
  intervalDays          Int? // for CUSTOM frequency
  startDate             DateTime?
  endDate               DateTime?
  nextServiceAt         DateTime
  lastServiceAt         DateTime?
  // Lead-times (in days before due) already emailed for the current cycle, so a
  // daily job doesn't send the same reminder twice.
  remindersSent         Int[]                @default([])
  active                Boolean              @default(true)
  notes                 String?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  @@index([clientId])
  @@index([active])
  @@index([nextServiceAt])
}

// A weighbridge registered by an administrator. Reports and schedules pick one
// from a dropdown; the make/model/serial/capacity auto-fill the service forms.
model Weighbridge {
  id         String  @id @default(cuid())
  clientId   String
  client     Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  site       String?
  label      String // e.g. "WB-1 Dispatch Gate"
  makeModel  String?
  serialNo   String?
  capacity   String? // capacity / division
  deckLength String?
  active     Boolean @default(true)

  // The Client/Manager responsible for this weighbridge — used to route the
  // final approval of reports filed against it.
  clientManagerId String?
  clientManager   User?   @relation("WeighbridgeManager", fields: [clientManagerId], references: [id], onDelete: SetNull)

  users User[] @relation("UserWeighbridges")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@index([active])
  @@index([clientManagerId])
}

// A recurring maintenance obligation for one weighbridge (e.g. WB01 daily on
// TATA Magadi's dispatch-gate weighbridge). Filing the matching report advances it.
model Schedule {
  id           String               @id @default(cuid())
  clientId     String?
  client       Client?              @relation(fields: [clientId], references: [id])
  clientName   String // snapshot
  site         String?
  weighbridgeId String?

  template     String // WB01..WB06
  templateName String
  frequency    MaintenanceFrequency
  intervalDays Int? // used when frequency = CUSTOM

  assignedName  String?
  assignedEmail String?

  lastDoneAt       DateTime?
  nextDueAt        DateTime
  lastReportSerial String?

  active      Boolean  @default(true)
  notes       String?
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([nextDueAt])
  @@index([clientId])
  @@index([template])
  @@index([active])
}

model Report {
  id           String       @id @default(cuid())
  serial       String       @unique
  template     String // WB01..WB06
  templateName String
  status       ReportStatus @default(PENDING_SUPERVISOR)

  clientId   String?
  client     Client? @relation(fields: [clientId], references: [id])
  clientName String // snapshot at time of submission
  site       String?

  weighbridgeId String?

  authorId   String?
  author     User?   @relation("AuthoredReports", fields: [authorId], references: [id])
  authorName String // snapshot

  // Primary Equipment User (kept for display / backward compatibility) and the
  // full set of Equipment Users the report is routed to. ANY one of them may
  // review it — the first to act decides, and an approval advances it to the
  // Client/Manager.
  supervisorEmail  String
  supervisorEmails String[] @default([])
  managerEmail     String

  // Structured form payload: { values, checks, grids, runs, weekly }
  data Json

  photos      Photo[]
  trailEvents TrailEvent[]

  // Set when an overdue pending approval was auto-escalated, so we don't re-nag.
  escalatedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([template])
  @@index([clientId])
  @@index([authorId])
  @@index([createdAt])
}

model Photo {
  id       String   @id @default(cuid())
  reportId String
  report   Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)
  // Base64 data URL (JPEG). For very large deployments swap to object storage.
  dataUrl  String   @db.Text
  caption  String?
  takenAt  DateTime?
  gpsLat   Float?
  gpsLng   Float?
  gpsAcc   Int?
  order    Int      @default(0)

  @@index([reportId])
}

model TrailEvent {
  id       String   @id @default(cuid())
  reportId String
  report   Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)
  action   String
  byName   String
  byUserId String?
  byUser   User?    @relation(fields: [byUserId], references: [id])
  comment  String?
  at       DateTime @default(now())

  @@index([reportId])
}

// Atomic per-year-per-template serial counter.
model Counter {
  scope String @id // e.g. "WB01-2026"
  value Int    @default(0)
}

// A calibration request raised by a CLIENT (CRF-NAWI). Lists the instruments to
// be calibrated and the client's declaration; the QSL laboratory (PM / TM) then
// completes the review checklist and accepts or rejects it.
model CalibrationRequest {
  id            String   @id @default(cuid())
  serial        String   @unique // QSL-CRF-2026-00001

  clientId   String?
  client     Client? @relation(fields: [clientId], references: [id])
  clientName String

  contactPerson String?
  address       String?
  telephone     String?
  email         String?

  // Equipment rows: [{ name, makeModel, serialNo, capacity, division, location, remarks }]
  equipment          Json
  calibrationType    CalibrationType?
  preferredDate      DateTime?
  additionalRequests String?

  // Customer declaration
  declarationName        String?
  declarationDesignation String?
  declarationDate        DateTime?

  status         CalibrationRequestStatus @default(SUBMITTED)
  // For laboratory use — review checklist:
  // { withinScope, standardsAvailable, uncertaintyAchievable, personnelAvailable,
  //   impartialityRisk, methodAvailable } each { yn: "YES"|"NO", remark }
  reviewChecklist Json?
  decisionReason  String?
  reviewedByName  String?
  approvedByName  String?
  reviewedAt      DateTime?

  requestedById   String?
  requestedByName String?

  quotations Quotation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@index([status])
  @@index([createdAt])
}

// A quotation. Requested by a CLIENT and prepared by a Project / Technical
// Manager. Visible only to the client who owns it and to PM / TM.
model Quotation {
  id         String          @id @default(cuid())
  number     String          @unique // QSL-Q-2026-00001
  clientId   String?
  client     Client?         @relation(fields: [clientId], references: [id])
  clientName String
  contactPerson String?
  contactEmail  String?

  status QuotationStatus @default(REQUESTED)

  // What the client asked to be quoted.
  requestNote     String?
  requestedById   String?
  requestedByName String?

  calibrationRequestId String?
  calibrationRequest   CalibrationRequest? @relation(fields: [calibrationRequestId], references: [id], onDelete: SetNull)

  // Line items: [{ description, qty, unit, unitPrice }]
  items         Json?
  currency      String  @default("KES")
  vatRate       Float   @default(16)
  freight       Float   @default(0)
  subtotal      Float   @default(0)
  vatAmount     Float   @default(0)
  grandTotal    Float   @default(0)
  amountInWords String?
  notes         String?
  validUntil    DateTime?

  preparedByName String?
  quotedAt       DateTime?
  decidedAt      DateTime?

  // The client's Local Purchase Order, uploaded as an image (base64 data URL,
  // capped at ~2 MB). Attached by the client around acceptance.
  lpoImage      String?   @db.Text
  lpoName       String?
  lpoUploadedAt DateTime?

  // Opaque, unguessable slug used to share the quotation PDF with a client. The
  // public link is /d/<shareToken>, so it reveals neither the record id nor the
  // API path. Minted lazily the first time the quote is opened by staff.
  shareToken String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@index([status])
  @@index([createdAt])
}

// A single-use, expiring token that lets a routed reviewer approve or reject a
// report straight from an email link, without signing in. Only the SHA-256 hash
// is stored; the raw token lives only in the emailed URL.
model ApprovalToken {
  id           String    @id @default(cuid())
  tokenHash    String    @unique
  reportSerial String
  stage        String // SUPERVISOR | MANAGER
  email        String
  expiresAt    DateTime
  usedAt       DateTime?
  createdAt    DateTime  @default(now())

  @@index([reportSerial])
}

// System-wide audit trail of create/update/delete actions across users,
// reports and schedules — visible to administrators.
model AuditLog {
  id        String   @id @default(cuid())
  at        DateTime @default(now())
  actorId   String?
  actorName String
  actorRole String?
  action    String // CREATE | UPDATE | DELETE | APPROVE | REJECT
  entity    String // USER | REPORT | SCHEDULE
  entityId  String?
  summary   String

  @@index([at])
  @@index([entity])
  @@index([actorId])
}
