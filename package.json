{
  "name": "qsl-maintenance-system",
  "version": "1.0.0",
  "private": true,
  "description": "QSL Weighbridge Maintenance Management System — production full-stack app (web + installable PWA) with PostgreSQL, secure auth, approval workflow and server-generated PDF reports.",
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "prisma generate && next build",
    "start": "next start",
    "start:render": "prisma migrate deploy && node prisma/seed.mjs && next start",
    "lint": "next lint",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:dev": "prisma migrate dev",
    "db:seed": "node prisma/seed.mjs",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "node prisma/seed.mjs"
  },
  "dependencies": {
    "@prisma/client": "^5.20.0",
    "@react-pdf/renderer": "^3.4.4",
    "bcryptjs": "^2.4.3",
    "exceljs": "^4.4.0",
    "jose": "^5.9.3",
    "next": "14.2.15",
    "nodemailer": "^6.9.15",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.15",
    "prisma": "^5.20.0"
  },
  "engines": {
    "node": ">=18.18.0"
  }
}
